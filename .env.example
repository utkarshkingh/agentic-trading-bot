# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Zerodha Kite Configuration (Optional - for self-hosted MCP server)
# If using the hosted MCP server at https://mcp.kite.trade/mcp, these are not required
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here

# MCP Server Configuration (Optional)
# Default: https://mcp.kite.trade/mcp (hosted version)
MCP_SERVER_URL=https://mcp.kite.trade/mcp

# Logging Configuration (Optional)
LOG_LEVEL=INFO