# Model provider — OPTIONAL. You can also set the model and API key from
# inside the app (Model panel in the sidebar), which persists to
# ~/.agentic-trading-bot/config.json. Anything set here just seeds the default.
# --------------------------------------------------
# Option A: OpenRouter (access to all models)
OPENROUTER_API_KEY=sk-or-v1-...
TRADING_MODEL=openrouter/qwen/qwen3-235b-a22b-thinking-2507

# Option B: OpenAI directly
# OPENAI_API_KEY=sk-...
# TRADING_MODEL=openai/gpt-4.1

# Option C: Anthropic directly
# ANTHROPIC_API_KEY=sk-ant-...
# TRADING_MODEL=anthropic/claude-sonnet-4-6

# Option D: Local Ollama
# TRADING_MODEL=ollama/qwen3:32b
# --------------------------------------------------

# Zerodha MCP server (remote)
# Get your Kite API credentials from kite.zerodha.com
ZERODHA_MCP_URL=https://mcp.kite.trade/mcp

# Backend port
PORT=8000

# Optional: custom risk-free rate for Sharpe ratio (annualized, default = 0.065 for India 10yr)
RISK_FREE_RATE=0.065
