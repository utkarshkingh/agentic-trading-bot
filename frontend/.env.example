# Base URL of the FastAPI AG-UI backend.
# Desktop: leave as localhost (the backend runs as a bundled sidecar).
# Mobile/hosted: set to your PC's LAN address or a deployed backend.
# This is baked in at build time; it can also be overridden at runtime
# from the in-app Backend settings (stored in localStorage).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000/
